APP_NAME=OKI CRM API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:3000
# Allows Next dev fallback ports and LAN/WSL-style dev origins during local development.
FRONTEND_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3}|192\.168\.\d{1,3}\.\d{1,3}):\d+$

# Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Use Supabase Postgres connection string (async SQLAlchemy format)
SUPABASE_DB_URL=postgresql+asyncpg://postgres.project-ref:password@aws-1-region.pooler.supabase.com:6543/postgres?ssl=require&prepared_statement_cache_size=0

# Redis connection used by Docker and future background jobs/websocket features
REDIS_URL=redis://localhost:6379/0

# Optional secret used to encrypt inbox channel credentials.
# Defaults to SUPABASE_JWT_SECRET when unset.
CHANNEL_CONFIG_SECRET=

# Token used by Meta webhook verification for Facebook/Instagram webhooks
META_WEBHOOK_VERIFY_TOKEN=

# Set to true only for local development if auth is not ready yet
ALLOW_ANON_DEV=false
