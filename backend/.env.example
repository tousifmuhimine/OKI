APP_NAME=OKI CRM API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:3000

# Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Use Supabase Postgres connection string (async SQLAlchemy format)
SUPABASE_DB_URL=postgresql+asyncpg://postgres:password@db.project-ref.supabase.co:5432/postgres

# Set to true only for local development if auth is not ready yet
ALLOW_ANON_DEV=false
